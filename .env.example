# Postgres
POSTGRES_DB=alma
POSTGRES_USER=alma
POSTGRES_PASSWORD=alma

# FastAPI backend
DATABASE_URL=postgresql://alma:alma@postgres:5432/alma
JWT_SECRET=change-me-to-a-random-32-char-string-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
CORS_ORIGINS=["http://localhost:3000"]
MAX_FILE_BYTES=10485760

# Resend (email) — non-blocking, 201 returns even if this fails
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev
ATTORNEY_EMAIL=attorney@example.com

# MinIO (object storage)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_BUCKET=resumes
PRESIGNED_URL_TTL_SECONDS=3600

# Frontend (passed as Docker build arg — baked into Next.js bundle at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000
